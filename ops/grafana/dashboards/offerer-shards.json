        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "sum by (shard_id) (count_over_time({service=\"offerer\", worker_id=~\"$offerer_id\", event=\"offer.refill_shard\"} | json [$__interval]))",
          "legendFormat": "shard_{{shard_id}}",
